# Outpulse API Key — required for backend authentication.
# Set this in .env.local for local dev and in Vercel env vars for production.
# The key is added server-side by the API proxy route, never exposed to the browser.
OUTPULSE_API_KEY=

# Optional. Override the upstream backend URL (defaults to the Railway prod URL).
# Useful for pointing the UI at a local backend or a staging deployment.
# OUTPULSE_BACKEND_URL=https://outpulse-production.up.railway.app
